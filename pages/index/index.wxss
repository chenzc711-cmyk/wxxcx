.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 56rpx;
  box-sizing: border-box;
}

.hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 28rpx;
  padding: 36rpx;
  border-radius: 32rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #0f766e 0%, #14b8a6 55%, #38bdf8 100%);
  box-shadow: 0 20rpx 50rpx rgba(15, 118, 110, 0.24);
}

.hero__eyebrow {
  display: block;
  margin-bottom: 8rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 22rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.hero__title {
  font-size: 46rpx;
  font-weight: 800;
  line-height: 1.2;
}

.hero__desc {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 24rpx;
}

.hero__badge {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.34);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
}

.nav {
  width: 100%;
  margin-bottom: 32rpx;
  white-space: nowrap;
}

.nav__item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #4b5563;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.nav__item--active {
  background: #0f766e;
  color: #ffffff;
}

.section-title {
  margin: 8rpx 0 22rpx;
  color: #111827;
  font-size: 34rpx;
  font-weight: 800;
}

.metrics {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.metric-card,
.panel,
.product-card,
.warehouse-card,
.channel-card,
.record-card {
  border: 1rpx solid #e5e7eb;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.06);
}

.metric-card {
  padding: 28rpx;
}

.metric-card--primary {
  background: #ecfdf5;
  border-color: #bbf7d0;
}

.metric-card--warning {
  background: #fff7ed;
  border-color: #fed7aa;
}

.metric-card__label,
.metric-card__hint,
.channel-row__count,
.product-card__meta,
.warehouse-card__location,
.channel-card__type,
.record-card__meta {
  color: #6b7280;
  font-size: 24rpx;
}

.metric-card__value {
  display: block;
  margin: 12rpx 0 10rpx;
  color: #0f172a;
  font-size: 40rpx;
  font-weight: 800;
}

.panel {
  margin-bottom: 24rpx;
  padding: 28rpx;
}

.panel__header,
.channel-row,
.product-card__main,
.product-card__stats,
.product-card__actions,
.warehouse-card,
.channel-card,
.record-card,
.warning-item,
.form-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.panel__header {
  margin-bottom: 20rpx;
}

.panel__title {
  font-size: 30rpx;
  font-weight: 800;
}

.panel__total,
.channel-row__amount,
.product-card__amount,
.channel-card__balance,
.record-card__qty,
.warehouse-card__stock {
  color: #0f766e;
  font-weight: 800;
}

.channel-row,
.warning-item {
  padding: 18rpx 0;
  border-top: 1rpx solid #f3f4f6;
}

.channel-row:first-of-type,
.warning-item:first-of-type {
  border-top: 0;
}

.channel-row__name,
.product-card__name,
.warehouse-card__name,
.channel-card__name,
.record-card__name {
  color: #111827;
  font-weight: 800;
}

.form-panel {
  margin-bottom: 24rpx;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.field {
  margin-bottom: 18rpx;
}

.field text {
  display: block;
  margin-bottom: 10rpx;
  color: #374151;
  font-size: 24rpx;
  font-weight: 700;
}

.field input,
.picker-value {
  width: 100%;
  min-height: 78rpx;
  padding: 0 22rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 18rpx;
  background: #f9fafb;
  color: #111827;
  line-height: 78rpx;
}

.form-actions {
  margin-top: 10rpx;
}

.btn {
  margin: 0;
  padding: 0 30rpx;
  border: 0;
  color: #111827;
  font-size: 26rpx;
  font-weight: 700;
}

.btn--primary {
  background: #0f766e;
  color: #ffffff;
}

.btn--ghost {
  background: #eef2f7;
  color: #374151;
}

.btn--danger {
  background: #fee2e2;
  color: #b91c1c;
}

.btn--full {
  width: 100%;
  margin-top: 8rpx;
}

.product-card,
.warehouse-card,
.channel-card,
.record-card {
  margin-bottom: 18rpx;
  padding: 26rpx;
}

.product-card__main {
  align-items: flex-start;
}

.product-card__stats {
  justify-content: flex-start;
  margin: 20rpx 0;
  color: #4b5563;
  font-size: 24rpx;
}

.product-card__actions {
  justify-content: flex-end;
}
