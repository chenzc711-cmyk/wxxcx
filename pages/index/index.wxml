<view class="page">
  <view class="hero">
    <view>
      <text class="hero__eyebrow">Warehouse Console</text>
      <view class="hero__title">仓库管理系统</view>
      <view class="hero__desc">库存、金额、渠道商款项与出入库流水一屏管理</view>
    </view>
    <view class="hero__badge">{{appVersion}}</view>
  </view>

  <scroll-view class="nav" scroll-x enhanced show-scrollbar="false">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="nav__item {{activeTab === item.key ? 'nav__item--active' : ''}}"
      data-key="{{item.key}}"
      bindtap="switchTab"
    >{{item.label}}</view>
  </scroll-view>

  <block wx:if="{{activeTab === 'dashboard'}}">
    <view class="section-title">仪表盘数据</view>
    <view class="metrics">
      <view class="metric-card metric-card--primary">
        <text class="metric-card__label">总库存数量</text>
        <text class="metric-card__value">{{dashboard.totalStock}}</text>
        <text class="metric-card__hint">所有商品在库数量合计</text>
      </view>
      <view class="metric-card">
        <text class="metric-card__label">库存总金额</text>
        <text class="metric-card__value">¥{{dashboard.totalAmount}}</text>
        <text class="metric-card__hint">在库数量 × 登记单价</text>
      </view>
      <view class="metric-card metric-card--warning">
        <text class="metric-card__label">库存预警</text>
        <text class="metric-card__value">{{dashboard.warningCount}}</text>
        <text class="metric-card__hint">低于预警线的商品</text>
      </view>
      <view class="metric-card">
        <text class="metric-card__label">商品总数</text>
        <text class="metric-card__value">{{dashboard.productCount}}</text>
        <text class="metric-card__hint">已登记商品数</text>
      </view>
      <view class="metric-card">
        <text class="metric-card__label">今日入库数量 / 金额</text>
        <text class="metric-card__value">{{dashboard.todayInboundQuantity}}</text>
        <text class="metric-card__hint">¥{{dashboard.todayInboundAmount}}</text>
      </view>
      <view class="metric-card">
        <text class="metric-card__label">今日出库数量 / 金额</text>
        <text class="metric-card__value">{{dashboard.todayOutboundQuantity}}</text>
        <text class="metric-card__hint">¥{{dashboard.todayOutboundAmount}}</text>
      </view>
      <view class="metric-card">
        <text class="metric-card__label">本月入库数量 / 金额</text>
        <text class="metric-card__value">{{dashboard.monthInboundQuantity}}</text>
        <text class="metric-card__hint">¥{{dashboard.monthInboundAmount}}</text>
      </view>
      <view class="metric-card">
        <text class="metric-card__label">本月出库数量 / 金额</text>
        <text class="metric-card__value">{{dashboard.monthOutboundQuantity}}</text>
        <text class="metric-card__hint">¥{{dashboard.monthOutboundAmount}}</text>
      </view>
      <view class="metric-card metric-card--wide">
        <text class="metric-card__label">本月累计出入库数量 / 金额</text>
        <text class="metric-card__value">{{dashboard.monthTotalQuantity}}</text>
        <text class="metric-card__hint">¥{{dashboard.monthTotalAmount}}</text>
      </view>
    </view>

    <view class="panel">
      <view class="panel__header">
        <text class="panel__title">渠道商剩余款项合计</text>
        <text class="panel__total">¥{{dashboard.channelTotal}}</text>
      </view>
      <view class="channel-row" wx:for="{{channelSummaries}}" wx:key="type">
        <view>
          <view class="channel-row__name">{{item.label}}</view>
          <view class="channel-row__count">{{item.count}} 位渠道商</view>
        </view>
        <view class="channel-row__amount">¥{{item.amount}}</view>
      </view>
    </view>

    <view class="panel" wx:if="{{warningProducts.length}}">
      <view class="panel__header">
        <text class="panel__title">库存预警商品</text>
      </view>
      <view class="warning-item" wx:for="{{warningProducts}}" wx:key="id">
        <text>{{item.name}}｜{{item.spec}}</text>
        <text>{{item.stock}} / {{item.warningLine}}</text>
      </view>
    </view>
  </block>

  <block wx:elif="{{activeTab === 'inventory'}}">
    <view class="section-title">库存数量与商品信息</view>
    <view class="panel form-panel">
      <view class="form-grid">
        <view class="field">
          <text>商品名称</text>
          <input value="{{productForm.name}}" data-field="name" bindinput="onProductInput" placeholder="如：洗护套装" />
        </view>
        <view class="field">
          <text>商品规格</text>
          <input value="{{productForm.spec}}" data-field="spec" bindinput="onProductInput" placeholder="如：500ml×2 / 礼盒装" />
        </view>
        <view class="field">
          <text>商品分类</text>
          <picker range="{{categoryNames}}" value="{{productForm.categoryIndex}}" bindchange="onCategoryPick">
            <view class="picker-value">{{selectedCategoryName}}</view>
          </picker>
        </view>
        <view class="field">
          <text>在库数量</text>
          <input type="number" value="{{productForm.stock}}" data-field="stock" bindinput="onProductInput" placeholder="0" />
        </view>
        <view class="field">
          <text>登记单价</text>
          <input type="digit" value="{{productForm.price}}" data-field="price" bindinput="onProductInput" placeholder="0.00" />
        </view>
        <view class="field">
          <text>预警线</text>
          <input type="number" value="{{productForm.warningLine}}" data-field="warningLine" bindinput="onProductInput" placeholder="10" />
        </view>
      </view>
      <view class="form-actions">
        <button class="btn btn--ghost" bindtap="resetProductForm">清空</button>
        <button class="btn btn--primary" bindtap="saveProduct">{{editingProductId ? '保存修改' : '新增商品'}}</button>
      </view>
    </view>

    <view class="product-card" wx:for="{{products}}" wx:key="id">
      <view class="product-card__main">
        <view>
          <view class="product-card__name">{{item.name}}</view>
          <view class="product-card__meta">{{item.spec}} · {{item.category}}</view>
        </view>
        <view class="product-card__amount">¥{{item.amount}}</view>
      </view>
      <view class="product-card__stats">
        <text>在库：{{item.stock}}</text>
        <text>单价：¥{{item.price}}</text>
        <text>预警：{{item.warningLine}}</text>
      </view>
      <view class="product-card__actions">
        <button size="mini" class="btn btn--ghost" data-id="{{item.id}}" bindtap="editProduct">编辑</button>
        <button size="mini" class="btn btn--danger" data-id="{{item.id}}" bindtap="deleteProduct">删除</button>
      </view>
    </view>
  </block>

  <block wx:elif="{{activeTab === 'channels'}}">
    <view class="section-title">渠道商剩余款项</view>
    <view class="panel form-panel">
      <view class="field">
        <text>渠道商名称</text>
        <input value="{{channelForm.name}}" data-field="name" bindinput="onChannelInput" placeholder="渠道商名称" />
      </view>
      <view class="field">
        <text>渠道类型</text>
        <picker range="{{channelTypeLabels}}" value="{{channelForm.typeIndex}}" bindchange="onChannelTypePick">
          <view class="picker-value">{{selectedChannelTypeLabel}}</view>
        </picker>
      </view>
      <view class="field">
        <text>剩余款项</text>
        <input type="digit" value="{{channelForm.balance}}" data-field="balance" bindinput="onChannelInput" placeholder="0.00" />
      </view>
      <button class="btn btn--primary btn--full" bindtap="saveChannel">新增渠道商</button>
    </view>
    <view class="channel-card" wx:for="{{channels}}" wx:key="id">
      <view>
        <view class="channel-card__name">{{item.name}}</view>
        <view class="channel-card__type">{{item.typeLabel}}</view>
      </view>
      <view class="channel-card__balance">¥{{item.balance}}</view>
    </view>
  </block>

  <block wx:else>
    <view class="section-title">{{recordTitle}}</view>

    <view class="panel form-panel" wx:if="{{activeTab === 'inbound'}}">
      <view class="form-grid">
        <view class="field">
          <text>入库日期</text>
          <picker mode="date" value="{{inboundForm.date}}" bindchange="onInboundDatePick">
            <view class="picker-value">{{inboundForm.date}}</view>
          </picker>
        </view>
        <view class="field">
          <text>商品名称</text>
          <input value="{{inboundForm.productName}}" data-field="productName" bindinput="onInboundInput" placeholder="入库商品名称" />
        </view>
        <view class="field">
          <text>供应商</text>
          <input value="{{inboundForm.supplier}}" data-field="supplier" bindinput="onInboundInput" placeholder="供应商名称" />
        </view>
        <view class="field">
          <text>数量</text>
          <input type="number" value="{{inboundForm.quantity}}" data-field="quantity" bindinput="onInboundInput" placeholder="0" />
        </view>
        <view class="field">
          <text>单价</text>
          <input type="digit" value="{{inboundForm.unitPrice}}" data-field="unitPrice" bindinput="onInboundInput" placeholder="0.00" />
        </view>
        <view class="field">
          <text>备注</text>
          <input value="{{inboundForm.remark}}" data-field="remark" bindinput="onInboundInput" placeholder="填写备注" />
        </view>
      </view>
      <button class="btn btn--primary btn--full" bindtap="saveInbound">登记入库记录</button>
    </view>

    <view class="panel form-panel" wx:elif="{{activeTab === 'outbound'}}">
      <view class="form-grid">
        <view class="field">
          <text>出库日期</text>
          <picker mode="date" value="{{outboundForm.date}}" bindchange="onOutboundDatePick">
            <view class="picker-value">{{outboundForm.date}}</view>
          </picker>
        </view>
        <view class="field">
          <text>商品名称</text>
          <input value="{{outboundForm.productName}}" data-field="productName" bindinput="onOutboundInput" placeholder="出库商品名称" />
        </view>
        <view class="field">
          <text>商品规格</text>
          <input value="{{outboundForm.spec}}" data-field="spec" bindinput="onOutboundInput" placeholder="商品规格" />
        </view>
        <view class="field">
          <text>数量</text>
          <input type="number" value="{{outboundForm.quantity}}" data-field="quantity" bindinput="onOutboundInput" placeholder="0" />
        </view>
      </view>
      <button class="btn btn--primary btn--full" bindtap="saveOutbound">登记出库记录</button>
    </view>

    <view class="panel form-panel" wx:else>
      <view class="form-grid">
        <view class="field">
          <text>退货日期</text>
          <picker mode="date" value="{{returnForm.date}}" bindchange="onReturnDatePick">
            <view class="picker-value">{{returnForm.date}}</view>
          </picker>
        </view>
        <view class="field">
          <text>订单号</text>
          <input value="{{returnForm.orderNo}}" data-field="orderNo" bindinput="onReturnInput" placeholder="订单编号" />
        </view>
        <view class="field">
          <text>物流公司</text>
          <input value="{{returnForm.logisticsCompany}}" data-field="logisticsCompany" bindinput="onReturnInput" placeholder="物流公司" />
        </view>
        <view class="field">
          <text>物流单号</text>
          <input value="{{returnForm.logisticsNo}}" data-field="logisticsNo" bindinput="onReturnInput" placeholder="物流单号" />
        </view>
        <view class="field">
          <text>商品名称</text>
          <input value="{{returnForm.productName}}" data-field="productName" bindinput="onReturnInput" placeholder="退货商品名称" />
        </view>
        <view class="field">
          <text>商品规格</text>
          <input value="{{returnForm.spec}}" data-field="spec" bindinput="onReturnInput" placeholder="商品规格" />
        </view>
        <view class="field">
          <text>数量</text>
          <input type="number" value="{{returnForm.quantity}}" data-field="quantity" bindinput="onReturnInput" placeholder="0" />
        </view>
        <view class="field">
          <text>操作人</text>
          <input value="{{returnForm.operator}}" data-field="operator" bindinput="onReturnInput" placeholder="操作人" />
        </view>
        <view class="field field--full">
          <text>备注</text>
          <input value="{{returnForm.remark}}" data-field="remark" bindinput="onReturnInput" placeholder="填写备注" />
        </view>
      </view>
      <button class="btn btn--primary btn--full" bindtap="saveReturnInbound">登记退货入库</button>
    </view>

    <view class="panel filter-panel">
      <view class="filter-panel__title">按日期筛选</view>
      <view class="form-grid">
        <view class="field">
          <text>开始日期</text>
          <picker mode="date" value="{{recordFilter.startDate}}" data-field="startDate" bindchange="onFilterDatePick">
            <view class="picker-value">{{recordFilter.startDate}}</view>
          </picker>
        </view>
        <view class="field">
          <text>结束日期</text>
          <picker mode="date" value="{{recordFilter.endDate}}" data-field="endDate" bindchange="onFilterDatePick">
            <view class="picker-value">{{recordFilter.endDate}}</view>
          </picker>
        </view>
      </view>
      <button class="btn btn--ghost btn--full" bindtap="resetDateFilter">重置为本月</button>
    </view>

    <view class="record-card" wx:for="{{visibleRecords}}" wx:key="id">
      <view>
        <view class="record-card__name">{{item.productName}}｜{{item.spec}}</view>
        <view class="record-card__meta">日期：{{item.date}} · 数量：{{item.quantity}} · 金额：¥{{item.amount}}</view>
        <view class="record-card__meta" wx:if="{{item.supplier}}">供应商：{{item.supplier}} · 单价：¥{{item.unitPrice}} · {{item.remark}}</view>
        <view class="record-card__meta" wx:if="{{item.orderNo}}">订单：{{item.orderNo}} · {{item.logisticsCompany}} {{item.logisticsNo}}</view>
        <view class="record-card__meta" wx:if="{{item.operator}}">操作人：{{item.operator}} · {{item.remark}}</view>
      </view>
    </view>
  </block>
</view>
